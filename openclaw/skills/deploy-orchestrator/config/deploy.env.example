# Runtime overrides for deploy-orchestrator
# Only plain KEY=VALUE entries are supported; shell expressions are treated as literal text.
DEPLOY_CONFIG_PATH=
DEPLOY_RUNTIME_DIR=
DEPLOY_SQLITE_PATH=
DEPLOY_REPO_DIR=
DEPLOY_ENVIRONMENT=production
DEPLOY_REGISTRY_PROVIDER=ghcr
DEPLOY_REGISTRY_BASE=ghcr.io
DEPLOY_REPOSITORY=owner/repo
DEPLOY_PACKAGE_NAME=web-app
# If DEPLOY_REPO_DIR is empty, deploy.sh falls back to $HOME/.openclaw/workspace/deploy_runtime.
DEPLOY_COMPOSE_FILE=/opt/web-app/docker-compose.yml
DEPLOY_NGINX_CONF=/opt/web-app/nginx/nginx.conf
# Service names are resolved from deploy-config.yaml -> services.{blue,green,edge}.
DEPLOY_PUBLIC_BASE_URL=http://localhost:8080
DEPLOY_HEALTH_ROUTE=/
DEPLOY_HEALTH_RETRIES=3
DEPLOY_HEALTH_TIMEOUT=10
DEPLOY_HEALTH_SLEEP=2
